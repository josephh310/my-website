---
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import HeadshotImage from '../assets/headshot.webp';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				display: flex;
				align-items: center;
				gap: 3em;
			}
			.hero-text {
				flex: 1;
			}
			.hero-text h1 {
				margin-bottom: 0.25em;
			}
			.hero-text .subtitle {
				font-size: 1.25em;
				color: rgb(var(--gray));
				margin-bottom: 1.5em;
			}
			.hero-text p {
				margin-bottom: 1em;
			}
			.hero-image {
				flex-shrink: 0;
			}
			.hero-image img {
				width: 220px;
				height: 220px;
				object-fit: cover;
				border-radius: 50%;
				box-shadow: var(--box-shadow);
			}
			@media (max-width: 720px) {
				.hero {
					flex-direction: column-reverse;
					gap: 2em;
					text-align: center;
				}
				.hero-image img {
					width: 180px;
					height: 180px;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="hero">
				<div class="hero-text">
					<h1>Hey, I'm Joseph</h1>
					<p class="subtitle">Developer on Roblox</p>
					<p>
						Welcome to my corner of the internet. I build interesting projects and games on Roblox.
						This is where I share my work, thoughts, and things I've learned along the way.
					</p>
					<p>
						If you're interested in what I do, feel free to check out my <a href="/blog">blog</a> or take a look at
						some of my <a href="/projects">projects</a>.
					</p>
				</div>
				<div class="hero-image">
					<Image src={HeadshotImage} alt="Joseph Hill" width={256} height={256} />
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>

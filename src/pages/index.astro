---
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import HeadshotImage from '../assets/headshot.webp';
import LuauIcon from '../assets/skill_icons/luau.svg';
import JavaScriptIcon from '../assets/skill_icons/javascript.svg';
import HtmlCssIcon from '../assets/skill_icons/html-css.svg';
import GitIcon from '../assets/skill_icons/git.svg';
import NodeJsIcon from '../assets/skill_icons/node-js.svg';
import RojoIcon from '../assets/skill_icons/rojo.png';
import VsCodeIcon from '../assets/skill_icons/vscode.svg';
import ClaudeIcon from '../assets/skill_icons/claude.svg';
import StudioIcon from '../assets/skill_icons/studio.svg';
import GitHubIcon from '../assets/skill_icons/github.svg';
import KocmocLogo from '../assets/experience_thumbnails/kocmoc.png';
import BrainySpinachLogo from '../assets/experience_thumbnails/brainy_spinach.png';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				display: flex;
				align-items: flex-start;
				gap: 3em;
			}
			.hero-text {
				flex: 1;
			}
			.hero-text h1 {
				margin-bottom: 0.25em;
			}
			.hero-text .subtitle {
				font-size: 1.25em;
				color: rgb(var(--gray));
				margin-bottom: 1.5em;
			}
			.hero-text p {
				margin-bottom: 1em;
			}
			.hero-image {
				flex-shrink: 0;
			}
			.hero-image img {
				width: 180px;
				height: 180px;
				object-fit: cover;
				border-radius: 50%;
				outline: 2px solid rgba(255, 255, 255, 0.7);
				outline-offset: -1px;
			}
			@keyframes fade-up {
				from {
					opacity: 0;
					transform: translateY(20px);
				}
				to {
					opacity: 1;
					transform: translateY(0);
				}
			}
			.stagger {
				opacity: 0;
				animation: fade-up 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
			}
			.stagger:nth-child(1) { animation-delay: 0.1s; }
			.stagger:nth-child(2) { animation-delay: 0.25s; }
			.stagger:nth-child(3) { animation-delay: 0.4s; }
			.stagger:nth-child(4) { animation-delay: 0.55s; }
			@keyframes fade-up-scale {
				from {
					opacity: 0;
					transform: translateY(20px) scale(0.85);
				}
				to {
					opacity: 1;
					transform: translateY(0) scale(1);
				}
			}
			.hero-image {
				opacity: 0;
				animation: fade-up-scale 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.15s both;
			}
			@media (max-width: 720px) {
				.hero {
					flex-direction: column-reverse;
					align-items: center;
					gap: 2em;
					text-align: center;
				}
				.hero-image img {
					width: 150px;
					height: 150px;
				}
			}
			.divider {
				border-top: 1px solid rgb(var(--gray-light));
			}
			.portfolio {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 3em 1em;
			}
			.portfolio h2 {
				margin-bottom: 0.5em;
			}
			.portfolio h3 {
				color: rgb(var(--gray));
				font-weight: 500;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="hero">
				<div class="hero-text">
					<h1 class="stagger">Hey, I'm Joseph</h1>
					<p class="subtitle stagger">Developer on Roblox</p>
					<p class="stagger">
						Welcome to my corner of the internet. I build interesting projects and games on Roblox. This is where I share my work, thoughts, and things I've learned along the way.
					</p>
					<p class="stagger">
						If you're interested in what I do, feel free to check out my <a href="/blog">blog</a> or take a look at some of my <a href="/projects">projects</a>. If you're potentially interested in hiring me, check out my portfolio below!
					</p>
				</div>
				<div class="hero-image">
					<Image src={HeadshotImage} alt="Joseph Hill" width={256} height={256} />
				</div>
			</div>
		</main>
		<div class="divider"></div>
		<section class="portfolio">
			<h2>My Portfolio</h2>
			<h3>Technical Skills</h3>
		</section>
		<Footer />
	</body>
</html>

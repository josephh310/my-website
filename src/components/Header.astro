---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
			<span class="tab-indicator" aria-hidden="true"></span>
		</div>
		<button class="theme-toggle" aria-label="Toggle theme">
			<svg class="icon-sun" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
				<circle cx="12" cy="12" r="5" fill="none" stroke="currentColor" stroke-width="2"/>
				<g stroke="currentColor" stroke-width="2" stroke-linecap="round">
					<line x1="12" y1="1" x2="12" y2="3"/>
					<line x1="12" y1="21" x2="12" y2="23"/>
					<line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
					<line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
					<line x1="1" y1="12" x2="3" y2="12"/>
					<line x1="21" y1="12" x2="23" y2="12"/>
					<line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
					<line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
				</g>
			</svg>
			<svg class="icon-moon" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
				<path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
					d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
			</svg>
		</button>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 2em;
		background: var(--header-bg);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border-bottom: 1px solid rgba(var(--gray-light), 0.8);
		position: sticky;
		top: 0;
		z-index: 100;
	}
	h2 {
		margin: 0;
		font-size: 1em;
		font-weight: 700;
		letter-spacing: -0.02em;
	}
	h2 a,
	h2 a.active {
		text-decoration: none;
		color: rgb(var(--black));
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 960px;
		margin: 0 auto;
	}
	.internal-links {
		position: relative;
		display: flex;
		align-items: center;
	}
	nav a {
		padding: 1.25em 0.75em;
		color: rgb(var(--gray));
		text-decoration: none;
		font-size: 0.95em;
		font-weight: 500;
		transition: color var(--transition);
	}
	nav a:hover {
		color: rgb(var(--black));
	}
	nav a.active {
		color: var(--accent);
		font-weight: 600;
	}
	.tab-indicator {
		position: absolute;
		bottom: 0;
		height: 2px;
		background: var(--accent);
		border-radius: 1px;
		transition: left 0.35s cubic-bezier(0.16, 1, 0.3, 1), width 0.35s cubic-bezier(0.16, 1, 0.3, 1);
		pointer-events: none;
	}
	.theme-toggle {
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 0.5em;
		border: none;
		border-radius: 8px;
		background: none;
		color: rgb(var(--gray));
		cursor: pointer;
		transition: color var(--transition), background var(--transition);
	}
	.theme-toggle:hover {
		color: var(--accent);
		background: var(--accent-subtle);
	}
	:global([data-theme="light"]) .icon-moon,
	:global(:not([data-theme="dark"])) .icon-moon {
		display: none;
	}
	:global([data-theme="dark"]) .icon-sun {
		display: none;
	}
	:global([data-theme="dark"]) .icon-moon {
		display: block;
	}
	@media (max-width: 720px) {
		header {
			padding: 0 1em;
		}
	}
</style>
<script>
	function positionIndicator(animate = true) {
		const container = document.querySelector('.internal-links') as HTMLElement;
		const active = container?.querySelector('a.active') as HTMLElement;
		const indicator = container?.querySelector('.tab-indicator') as HTMLElement;
		if (!container || !active || !indicator) return;

		if (!animate) indicator.style.transition = 'none';

		const containerRect = container.getBoundingClientRect();
		const activeRect = active.getBoundingClientRect();
		indicator.style.left = `${activeRect.left - containerRect.left}px`;
		indicator.style.width = `${activeRect.width}px`;

		if (!animate) {
			indicator.offsetHeight; // force reflow
			indicator.style.transition = '';
		}
	}

	function attachToggle() {
		document.querySelector('.theme-toggle')?.addEventListener('click', () => {
			const current = document.documentElement.getAttribute('data-theme');
			const next = current === 'dark' ? 'light' : 'dark';
			document.documentElement.setAttribute('data-theme', next);
			localStorage.setItem('theme', next);
		});
	}

	// Initial setup
	positionIndicator(false);
	attachToggle();

	// Re-attach after client-side navigation
	document.addEventListener('astro:after-swap', () => {
		positionIndicator(true);
		attachToggle();
	});
</script>
